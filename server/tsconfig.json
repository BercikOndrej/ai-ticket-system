{
  "compilerOptions": {
    "rootDir": "..",
    "outDir": "dist",
    "module": "commonjs",
    "target": "es2020",
    "types": ["node", "module"],
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "core/schemas/users": ["../core/src/schemas/users.ts"],
      "core/schemas/tickets": ["../core/src/schemas/tickets.ts"],
      "core/enums": ["../core/src/enums.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
